{
  "name": "nutritrack",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c green,blue \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "build": "npm run build -w frontend",
    "seed": "npm run seed -w backend",
    "start": "npm start -w backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
